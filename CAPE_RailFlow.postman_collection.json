					"name": "Step 1: Send Rainy IoT Data",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sf_front_distance\": 120.00,\n    \"sf_side_distance\": 100.00,\n    \"t_front_distance\": 180.00,\n    \"temperature\": 23.50,\n    \"humidity\": 88.00,\n    \"lux\": 250.00,\n    \"rain_percentage\": 55.00,\n    \"latitude\": 6.92000000,\n    \"longitude\": 79.97000000,\n    \"speed\": 25.00\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/iot/history",
							"host": ["{{baseUrl}}"],
							"path": ["api", "iot", "history"]
						},
						"description": "High humidity (88%) + heavy rain (55%) + normal light. No obstacle, low flood → triggers Medium."
					}
				},
				{
					"name": "Step 2: Send Low Flood Report",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"latitude\": 6.92000000,\n    \"longitude\": 79.97000000,\n    \"city\": \"Nugegoda\",\n    \"risk_level\": \"Low\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/disaster-history",
							"host": ["{{baseUrl}}"],
							"path": ["api", "disaster-history"]
						},
						"description": "Low flood risk — won't trigger High by itself."
					}
				},
				{
					"name": "Step 3: Trigger CAPE Assessment",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/cape/assess",
							"host": ["{{baseUrl}}"],
							"path": ["api", "cape", "assess"]
						},
						"description": "Expected result: MEDIUM risk — high humidity + heavy rain combination."
					}
				}
			],
			"description": "Heavy rain + high humidity, no obstacle. CAPE should return **Medium** risk."
		},
		{
			"name": "💬 CAPE Chat",
			"item": [
				{
					"name": "Ask CAPE a Question",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"question\": \"What is the current risk level and what should the driver do?\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/cape/chat",
							"host": ["{{baseUrl}}"],
							"path": ["api", "cape", "chat"]
						},
						"description": "Ask CAPE about the current risk assessment. Uses the latest CapeRiskLog context."
					}
				},
				{
					"name": "Ask About Specific Factor",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"question\": \"Is it safe to increase speed given the current weather conditions?\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/cape/chat",
							"host": ["{{baseUrl}}"],
							"path": ["api", "cape", "chat"]
						},
						"description": "Ask CAPE about speed safety related to current conditions."
					}
				}
			],
			"description": "Chat with CAPE about the most recent risk assessment."
		},
		{
			"name": "🔍 Utility",
			"item": [
				{
					"name": "Get Latest IoT + Weather + Detection",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/iot/latest",
							"host": ["{{baseUrl}}"],
							"path": ["api", "iot", "latest"]
						},
						"description": "Fetches the combined latest data — same structure CAPE reads internally."
					}
				}
			],
			"description": "Utility endpoints for debugging."
		}
	]
